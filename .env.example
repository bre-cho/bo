# ============================================================
# Deriv API Credentials
# ============================================================
DERIV_ENV=demo
# Khuyen nghi: dung 2 token rieng cho demo/live
DERIV_API_TOKEN_DEMO=YOUR_DERIV_DEMO_TOKEN_HERE
DERIV_API_TOKEN_LIVE=
# Tuong thich nguoc (se duoc dung neu token theo mode chua set)
DERIV_API_TOKEN=
DERIV_APP_ID=1089
LIVE_TRADING_ENABLED=false

# ============================================================
# Redis Connection
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ============================================================
# API Server
# ============================================================
API_SECRET_KEY=change_this_to_a_long_random_string

# ============================================================
# LLM (optional — leave empty to disable)
# ============================================================
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
