# ============================================================
# Deriv API Credentials
# ============================================================
DERIV_APP_ID=YOUR_APP_ID
DERIV_API_TOKEN=YOUR_TOKEN
DERIV_WS_URL=wss://ws.derivws.com/websockets/v3?app_id=YOUR_APP_ID

ENGINE_MODE=PAPER
TRADE_MODE=PAPER
LIVE_TRADING_ENABLED=false

# ============================================================
# Redis Connection
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ============================================================
# API Server
# ============================================================
API_SECRET_KEY=change_this_to_a_long_random_string

# ============================================================
# LLM (optional — leave empty to disable)
# ============================================================
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
